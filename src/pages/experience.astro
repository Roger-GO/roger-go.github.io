---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Rogelio Gracia Otalvaro | Experience & Skills"
  description="My work history, from project management in Madrid to research and teaching at Embry-Riddle. Plus awards, grants, and the tools I use."
>
<div class="sub has-bg">
  <div class="section__bg" data-align="left" aria-hidden="true">
    <canvas data-dynamics="lorenz" data-direction="ltr" data-duration="3200" data-color="#5EC8FF" data-scale-mul="2.2"></canvas>
  </div>
  <a href="/" class="sub__back">&larr; Home</a>
  <h1 class="sub__title">Experience & Skills</h1>
  <div class="dyn-tag" aria-hidden="true"><span class="dyn-tag__kicker">Behind the text</span><span class="dyn-tag__name">Lorenz attractor</span><span class="dyn-tag__sub">deterministic chaos on two wings</span></div>
  <p class="sub__intro">Professional experience across academia, research, financial analysis, and operations management in the U.S. and Spain.</p>

  <h2>Professional Experience</h2>
  <div class="cards">
    <div class="card">
      <div class="card__top">
        <div>
          <div class="card__role">Visiting Assistant Professor</div>
          <div class="card__org">Embry-Riddle Aeronautical University &middot; Daytona Beach, FL</div>
        </div>
        <div class="card__meta">Jan 2026 &ndash; Present</div>
      </div>
      <ul class="card__list">
        <li>Teaching undergraduate and graduate courses in Signals and Systems, Optimization, and Digital Communications</li>
        <li>Conducting research in resilience engineering, multi-agent reinforcement learning, complex systems analysis, LLM fine-tuning, and decentralized strategies for critical infrastructure optimization</li>
      </ul>
    </div>
    <div class="card">
      <div class="card__top">
        <div>
          <div class="card__role">Graduate Research / Teaching Assistant</div>
          <div class="card__org">Embry-Riddle Aeronautical University &middot; Daytona Beach, FL</div>
        </div>
        <div class="card__meta">Aug 2021 &ndash; Dec 2025</div>
      </div>
      <ul class="card__list">
        <li>Led machine learning and AI data-driven initiatives in the BID4R lab, directing cross-functional research teams</li>
        <li>Conducted research in resilience engineering, bifurcation analysis, bio-inspired design, aerial robotics, and ML applications</li>
        <li>Published findings in 10+ conference and symposium proceedings (INCOSE, ASME IDETC, AIAA)</li>
        <li>Developed and delivered course content for 150+ students in Electrical Engineering and Systems courses</li>
        <li>Utilized MATLAB, Python, AnyLogic, and cloud services for complex dynamic systems modeling</li>
        <li>Mentored two undergraduate research projects resulting in poster presentations</li>
      </ul>
    </div>
    <div class="card">
      <div class="card__top">
        <div>
          <div class="card__role">Associate Quantitative Analyst</div>
          <div class="card__org">IMAGINE + INVERSION &middot; Madrid, Spain</div>
        </div>
        <div class="card__meta">Feb 2021 &ndash; Aug 2021</div>
      </div>
      <ul class="card__list">
        <li>Engineered data mining strategy using SQL and Excel to evaluate 700+ companies, achieving 50% reply rate from decision-makers</li>
        <li>Delivered data-driven BI presentations to investment committees</li>
        <li>Built financial models to assess tech startups' growth potential</li>
      </ul>
    </div>
    <div class="card">
      <div class="card__top">
        <div>
          <div class="card__role">Project Manager</div>
          <div class="card__org">BALLESOL &middot; Madrid, Spain</div>
        </div>
        <div class="card__meta">Oct 2018 &ndash; Jan 2020</div>
      </div>
      <ul class="card__list">
        <li>Led creation of centralized business model, reducing operational costs by 30%</li>
        <li>Monitored operational efficiency across 45+ residential sites using custom KPIs, reducing delivery timelines by 20%</li>
      </ul>
    </div>
  </div>

  <h2>Awards & Grants</h2>
  <div class="cards">
    <div class="card">
      <div class="card__top">
        <div>
          <div class="card__role">SCEEE Development Grant</div>
          <div class="card__org">Bio-inspired Electrical Grid Design &middot; Investigator & Grant Composer</div>
        </div>
        <div class="card__meta">2024 &ndash; 2025<br><span class="card__amount">$80,000</span></div>
      </div>
    </div>
    <div class="card">
      <div class="card__top">
        <div>
          <div class="card__role">Philanthropy Council Grant</div>
          <div class="card__org">UAV Swarm Navigation for SAR &middot; Investigator & Grant Composer</div>
        </div>
        <div class="card__meta">2024<br><span class="card__amount">$4,000</span></div>
      </div>
    </div>
    <div class="card">
      <div class="card__top">
        <div>
          <div class="card__role">SPARK Travel Grants</div>
          <div class="card__org">Research dissemination and conference participation</div>
        </div>
        <div class="card__meta">2023 &ndash; 2025<br><span class="card__amount">$1,600</span></div>
      </div>
    </div>
    <div class="card">
      <div class="card__top">
        <div>
          <div class="card__role">Graduate Research Symposium</div>
          <div class="card__org">Poster Competition: Second Place & People's Choice Award</div>
        </div>
        <div class="card__meta">2024<br><span class="card__amount">$500</span></div>
      </div>
    </div>
    <div class="card">
      <div class="card__top">
        <div>
          <div class="card__role">FinDER Summer School</div>
          <div class="card__org">Frontiers in Engineering Design Research &middot; Selected participant</div>
        </div>
        <div class="card__meta">2023</div>
      </div>
    </div>
  </div>

  <h2>Invited Talks</h2>
  <div class="cards">
    <div class="card">
      <div class="card__top">
        <div>
          <div class="card__role">INCOSE CIPRWG</div>
          <div class="card__org">Critical Infrastructure Protection and Recovery Working Group &middot; Invited Speaker</div>
        </div>
        <div class="card__meta">February 2026</div>
      </div>
      <p class="card__desc">"Resilience Engineering via Bifurcation and Ecological Network Analysis: Demonstrated in an Electric Power Case Study"</p>
    </div>
  </div>

  <h2>Skills</h2>
  <div class="skills__grid">
    <div>
      <div class="skill-group__title">Languages</div>
      <div class="skill-group__items">
        <span>Spanish (Native)</span><span>English (Fluent)</span>
      </div>
    </div>
    <div>
      <div class="skill-group__title">Programming</div>
      <div class="skill-group__items">
        <span>Python</span><span>MATLAB & Simulink</span><span>SQL</span><span>C++</span><span>Java</span><span>JavaScript</span><span>React</span><span>CSS/HTML</span>
      </div>
    </div>
    <div>
      <div class="skill-group__title">ML / AI</div>
      <div class="skill-group__items">
        <span>PyTorch</span><span>TensorFlow</span><span>Deep Learning</span><span>Reinforcement Learning</span>
      </div>
    </div>
    <div>
      <div class="skill-group__title">Data & Analytics</div>
      <div class="skill-group__items">
        <span>Power BI</span><span>Excel</span><span>AnyLogic</span>
      </div>
    </div>
    <div>
      <div class="skill-group__title">Cloud & DevOps</div>
      <div class="skill-group__items">
        <span>Google Cloud Platform</span><span>Linux</span>
      </div>
    </div>
    <div>
      <div class="skill-group__title">Tools & Methods</div>
      <div class="skill-group__items">
        <span>Unity 3D</span><span>Jira</span><span>Agile/Scrum</span><span>Trello</span>
      </div>
    </div>
  </div>
</div>
</BaseLayout>
