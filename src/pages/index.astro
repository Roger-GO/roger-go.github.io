  <div class="hero__orb hero__orb--1"></div>
  <div class="hero__orb hero__orb--2"></div>
  <div class="hero__orb hero__orb--3"></div>
  <div class="hero__content hero__content--split">
    <div class="hero__text">
      <a href="#contact" class="pill pill--available">
        <span class="pill__dot"></span>
        Work with me
      </a>
      <h1 class="hero__name">Rogelio Gracia<br/>Otalvaro</h1>
      <p class="hero__sub">Visiting Assistant Professor at Embry-Riddle Aeronautical University. Ph.D. in Computer Science and Electrical Engineering. I keep critical infrastructure and complex systems <span class="serif">more resilient</span> through <span class="serif">bifurcation analysis</span>, machine learning, and mathematical modeling.</p>
    <div class="hero__actions">
      <a href="#contact" class="btn btn--primary">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
