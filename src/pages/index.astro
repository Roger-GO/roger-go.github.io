  description="Rogelio Gracia Otalvaro, Ph.D. Visiting Assistant Professor at Embry-Riddle Aeronautical University. Resilience engineering, machine learning, and complex systems research."
>

<!-- ═══ HERO ═══ -->
<section class="hero" id="hero">
