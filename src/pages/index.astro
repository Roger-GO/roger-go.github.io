<style is:global>
  /* Translucent .has-bg .card styles in global.css */

  /* ═══ Scroll note below hero social links ═══ */
  .hero__scroll-note {
    margin-top: 20px;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: .95rem;
    line-height: 1.5;
    color: #5EC8FF;
    letter-spacing: -.005em;
    animation: fadeUp .8s var(--ease) .45s both;
  }

  /* Dynamics backdrop and dyn-tag styles now live in global.css so subpages share them */

  /* ═══ Hero two-column split ═══ */
  .hero__content--split {
    max-width: 1100px;
    width: 100%;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: 64px;
    align-items: center;
    text-align: left;
  }
  .hero__content--split .hero__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    min-width: 0;
  }
  .hero__content--split .pill { margin-bottom: 20px; }
  .hero__content--split .hero__name { text-align: left; }
  .hero__content--split .hero__sub {
    margin-left: 0;
    margin-right: 0;
    max-width: 52ch;
    text-align: left;
  }
  .hero__content--split .hero__actions { justify-content: flex-start; }
  .hero__content--split .hero__social { justify-content: flex-start; margin-top: 24px; }

  @media (max-width: 900px) {
    .hero__content--split {
      grid-template-columns: 1fr;
      gap: 36px;
      text-align: center;
    }
