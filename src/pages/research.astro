---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Rogelio Gracia Otalvaro | Research & Publications"
  description="My research on resilience engineering, bifurcation analysis, reinforcement learning, and complex systems. Full list of publications, funded projects, and theses."
>
<div class="sub has-bg">
  <div class="section__bg section__bg--soft" aria-hidden="true">
    <canvas data-dynamics="hopf" data-direction="ltr" data-orientation="vertical" data-duration="2400" data-color="#5EC8FF"></canvas>
  </div>
  <a href="/" class="sub__back">&larr; Home</a>
  <h1 class="sub__title">Research & Publications</h1>
  <div class="dyn-tag" aria-hidden="true"><span class="dyn-tag__kicker">Behind the text</span><span class="dyn-tag__name">Hopf bifurcation</span><span class="dyn-tag__sub">birth of a limit cycle</span></div>
  <p class="sub__intro">My research applies bifurcation theory, ecological network analysis, and reinforcement learning to problems in infrastructure resilience and autonomous systems.</p>

  <!-- Funding stats -->
  <div class="stats" style="margin: 0 0 40px; padding: 0;">
    <div class="stat"><div class="stat__num">$80K</div><div class="stat__label">SCEEE Grant</div></div>
    <div class="stat"><div class="stat__num">$4K</div><div class="stat__label">Philanthropy Grant</div></div>
    <div class="stat"><div class="stat__num">$1.6K</div><div class="stat__label">Travel Grants</div></div>
    <div class="stat"><div class="stat__num">6+</div><div class="stat__label">Publications</div></div>
  </div>

