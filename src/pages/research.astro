        <div class="card__meta"><span class="badge badge--pub">Accepted</span><br>Jun 2026</div>
      </div>
    </div>
    <div class="card">
      <div class="card__top">
        <div>
          <div class="card__role">Evaluating Complex System Resilience Through BARD: A Bifurcation Analysis for Resilience Diagnostics Framework</div>
